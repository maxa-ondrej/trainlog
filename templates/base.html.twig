<!DOCTYPE html>
<html lang="cs">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}TrainLog{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.1em%22 font-size=%22104%22>🏋️</text></svg>">
        {% block stylesheets %}{% endblock %}
        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body>
        <header style="font-family: system-ui, sans-serif; padding: 0.75rem 1rem; border-bottom: 1px solid #ddd;">
            <nav style="max-width: 960px; margin: 0 auto; display: flex; gap: 1rem; align-items: center;">
                <a href="{{ path('home') }}" style="font-weight: bold; text-decoration: none;">🏋️ TrainLog</a>
                <span style="flex: 1;"></span>
                {% if is_granted('ROLE_ADMIN') %}
                    <a href="{{ path('admin_home') }}">Admin</a>
                {% endif %}
                {% if app.user %}
                    <span>{{ app.user.name }}</span>
                    <form method="post" action="{{ path('app_logout') }}" style="margin:0;">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('logout') }}">
                        <button type="submit" style="background: none; border: none; color: inherit; cursor: pointer; text-decoration: underline; padding: 0;">Odhlásit</button>
                    </form>
                {% else %}
                    <a href="{{ path('app_login') }}">Přihlášení</a>
                    <a href="{{ path('app_register') }}">Registrace</a>
                {% endif %}
            </nav>
        </header>
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div style="max-width: 960px; margin: 1rem auto; padding: 0.5rem 1rem; border-radius: 4px; background: {{ label == 'error' ? '#fee' : '#efe' }}; color: {{ label == 'error' ? '#900' : '#070' }};">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}
        {% block body %}{% endblock %}
    </body>
</html>
