{% extends 'base.html.twig' %}

{% block title %}TrainLog — přihlášení{% endblock %}

{% block body %}
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <h1 class="h3 mb-3">Přihlášení</h1>

            {% if error %}
                <div class="alert alert-danger" role="alert">
                    {{ error.messageKey|trans(error.messageData, 'security') }}
                </div>
            {% endif %}

            <form method="post">
                <div class="mb-3">
                    <label for="username" class="form-label">E-mail</label>
                    <input type="email" class="form-control" name="_username" id="username" value="{{ last_username }}" required autofocus>
                </div>
                <div class="mb-3">
                    <label for="password" class="form-label">Heslo</label>
                    <input type="password" class="form-control" name="_password" id="password" required>
                </div>
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
                <button type="submit" class="btn btn-primary">Přihlásit se</button>
            </form>

            <p class="mt-3 text-secondary">
                Nemáte účet? <a href="{{ path('app_register') }}">Zaregistrujte se</a>.
            </p>
        </div>
    </div>
{% endblock %}
