<nav class="navbar navbar-expand-lg bg-body-tertiary border-bottom">
    <div class="container">
        <a class="navbar-brand" href="{{ path('home') }}">🏋️ TrainLog</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
                aria-controls="mainNavbar" aria-expanded="false" aria-label="Přepnout navigaci">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="mainNavbar">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                <li class="nav-item">
                    <a class="nav-link{% if app.request.get('_route') == 'home' %} active{% endif %}" href="{{ path('home') }}">Domů</a>
                </li>
                {% if app.user %}
                    <li class="nav-item">
                        <a class="nav-link{% if app.request.get('_route') starts with 'exercise_' %} active{% endif %}" href="{{ path('exercise_index') }}">Cviky</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link{% if app.request.get('_route') starts with 'workout_' %} active{% endif %}" href="{{ path('workout_index') }}">Tréninky</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link{% if app.request.get('_route') starts with 'template_' %} active{% endif %}" href="{{ path('template_index') }}">Šablony</a>
                    </li>
                {% endif %}
                {% if is_granted('ROLE_ADMIN') %}
                    <li class="nav-item">
                        <a class="nav-link{% if app.request.get('_route') starts with 'admin_' %} active{% endif %}" href="{{ path('admin_home') }}">Administrace</a>
                    </li>
                {% endif %}
                <li class="nav-item">
                    <a class="nav-link{% if app.request.get('_route') starts with 'help_' %} active{% endif %}" href="{{ path('help_index') }}">Návod</a>
                </li>
            </ul>
            <ul class="navbar-nav">
                {% if app.user %}
                    <li class="nav-item d-flex align-items-center px-2 text-secondary">{{ app.user.name }}</li>
                    <li class="nav-item">
                        <form method="post" action="{{ path('app_logout') }}" class="d-inline">
                            <input type="hidden" name="_csrf_token" value="{{ csrf_token('logout') }}">
                            <button type="submit" class="btn btn-outline-secondary btn-sm">Odhlásit</button>
                        </form>
                    </li>
                {% else %}
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_login') }}">Přihlášení</a>
                    </li>
                    <li class="nav-item">
                        <a class="btn btn-primary btn-sm ms-2" href="{{ path('app_register') }}">Registrace</a>
                    </li>
                {% endif %}
            </ul>
        </div>
    </div>
</nav>
