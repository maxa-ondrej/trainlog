{% extends 'base.html.twig' %}

{% block title %}TrainLog — šablony{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0">Šablony tréninků</h1>
        <a class="btn btn-primary btn-sm" href="{{ path('template_new') }}">+ Nová šablona</a>
    </div>

    {% if templates is empty %}
        <div class="alert alert-info">
            Zatím žádné šablony. Vytvořte si šablonu typického tréninku a pak ji rychle spouštějte v nový trénink.
        </div>
    {% else %}
        <div class="row g-3">
            {% for t in templates %}
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100">
                        <div class="card-body">
                            <h2 class="h5">{{ t.name }}</h2>
                            {% if t.note %}<p class="text-secondary small">{{ t.note }}</p>{% endif %}
                            <p class="mb-2"><span class="badge text-bg-light border">{{ t.sets|length }} sad</span></p>
                            <ul class="small text-secondary mb-0">
                                {% set seen = [] %}
                                {% for s in t.sets %}
                                    {% if s.exercise and s.exercise.id not in seen %}
                                        {% set seen = seen|merge([s.exercise.id]) %}
                                        <li>{{ s.exercise.name }}</li>
                                    {% endif %}
                                {% endfor %}
                            </ul>
                        </div>
                        <div class="card-footer d-flex justify-content-between">
                            <a class="btn btn-sm btn-outline-secondary" href="{{ path('workout_show', {id: t.id}) }}">Detail</a>
                            <form method="post" action="{{ path('workout_from_template', {id: t.id}) }}" class="d-inline">
                                <input type="hidden" name="_token" value="{{ csrf_token('workout_from_template_' ~ t.id) }}">
                                <button type="submit" class="btn btn-sm btn-primary">Spustit trénink</button>
                            </form>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
{% endblock %}
