{{ form_start(form) }}
    <div class="row g-3">
        <div class="col-md-6">{{ form_row(form.name) }}</div>
        <div class="col-md-3">{{ form_row(form.performedAt) }}</div>
        <div class="col-md-3">{{ form_row(form.durationMinutes) }}</div>
    </div>
    {{ form_row(form.note) }}
    {{ form_widget(form.isTemplate) }}

    {% set prototypeHtml %}{% include 'workout/_set_row.html.twig' with {set: form.sets.vars.prototype} %}{% endset %}

    <h2 class="h5 mt-4 mb-2">Série</h2>
    <div data-controller="collection"
         data-collection-prototype-value="{{ prototypeHtml|e('html_attr') }}"
         data-collection-index-value="{{ form.sets|length }}">
        <div data-collection-target="container">
            {% for set in form.sets %}
                {% include 'workout/_set_row.html.twig' with {set: set} %}
            {% endfor %}
        </div>
        <button type="button" class="btn btn-outline-primary btn-sm mb-3" data-action="collection#add">+ Přidat sadu</button>
    </div>

    <div class="mt-3">
        <button type="submit" class="btn btn-primary">{{ submitLabel }}</button>
        <a class="btn btn-outline-secondary" href="{{ cancelUrl }}">Zrušit</a>
    </div>
{{ form_end(form) }}
