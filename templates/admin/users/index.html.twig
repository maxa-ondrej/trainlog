{% extends 'base.html.twig' %}
{% import '_macros.html.twig' as ui %}

{% block title %}TrainLog — uživatelé{% endblock %}

{% block body %}
    <p><a href="{{ path('admin_home') }}" class="text-decoration-none">← Administrace</a></p>
    <h1 class="h3 mb-4">Uživatelé</h1>
    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>E-mail</th>
                    <th>Jméno</th>
                    <th>Role</th>
                    <th>Registrace</th>
                    <th class="text-end">Akce</th>
                </tr>
            </thead>
            <tbody>
                {% for user in users %}
                    <tr>
                        <td>{{ user.email }}</td>
                        <td>{{ user.name }}</td>
                        <td>
                            {% if user.role.value == 'ROLE_ADMIN' %}
                                <span class="badge text-bg-primary">admin</span>
                            {% else %}
                                <span class="badge text-bg-secondary">user</span>
                            {% endif %}
                        </td>
                        <td>{{ user.createdAt|date('Y-m-d') }}</td>
                        <td class="text-end">
                            {% if user != app.user %}
                                <form method="post" action="{{ path('admin_user_toggle_role', {id: user.id}) }}" class="d-inline">
                                    <input type="hidden" name="_token" value="{{ csrf_token('admin_user_toggle_role_' ~ user.id) }}">
                                    <button type="submit" class="btn btn-sm btn-outline-primary">
                                        {{ user.role.value == 'ROLE_ADMIN' ? 'Degradovat' : 'Povýšit' }}
                                    </button>
                                </form>
                                {{ ui.delete_form(path('admin_user_delete', {id: user.id}), 'admin_user_delete_' ~ user.id, 'Opravdu smazat uživatele ' ~ user.email ~ '?') }}
                            {% else %}
                                <span class="text-secondary">(vy)</span>
                            {% endif %}
                        </td>
                    </tr>
                {% else %}
                    <tr><td colspan="5" class="text-secondary"><em>Žádní uživatelé.</em></td></tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
