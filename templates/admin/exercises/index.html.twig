{% extends 'base.html.twig' %}
{% import '_macros.html.twig' as ui %}

{% block title %}TrainLog — cviky{% endblock %}

{% block body %}
    <p><a href="{{ path('admin_home') }}" class="text-decoration-none">← Administrace</a></p>
    <h1 class="h3 mb-4">Cviky</h1>
    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>Název</th>
                    <th>Vlastník</th>
                    <th>Veřejný</th>
                    <th>Svalové partie</th>
                    <th class="text-end">Akce</th>
                </tr>
            </thead>
            <tbody>
                {% for exercise in exercises %}
                    <tr>
                        <td>{{ exercise.name }}</td>
                        <td>{{ exercise.owner ? exercise.owner.email : '—' }}</td>
                        <td>
                            {% if exercise.isPublic %}
                                <span class="badge text-bg-success">veřejný</span>
                            {% else %}
                                <span class="badge text-bg-secondary">soukromý</span>
                            {% endif %}
                        </td>
                        <td>
                            {% for mg in exercise.muscleGroups %}
                                <span class="badge text-bg-light border">{{ mg.name }}</span>
                            {% endfor %}
                        </td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-secondary" href="{{ path('exercise_edit', {id: exercise.id}) }}">Upravit</a>
                            <form method="post" action="{{ path('admin_exercise_toggle_public', {id: exercise.id}) }}" class="d-inline">
                                <input type="hidden" name="_token" value="{{ csrf_token('admin_exercise_toggle_public_' ~ exercise.id) }}">
                                <button type="submit" class="btn btn-sm btn-outline-primary">
                                    {{ exercise.isPublic ? 'Skrýt' : 'Zveřejnit' }}
                                </button>
                            </form>
                            {% if exercise.isPublic %}
                                {{ ui.delete_form(path('admin_exercise_delete', {id: exercise.id}), 'admin_exercise_delete_' ~ exercise.id, 'Opravdu smazat cvik „' ~ exercise.name ~ '"?') }}
                            {% endif %}
                        </td>
                    </tr>
                {% else %}
                    <tr><td colspan="5" class="text-secondary"><em>Žádné cviky.</em></td></tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
