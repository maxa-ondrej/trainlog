{% extends 'base.html.twig' %}

{% block title %}TrainLog — svalové partie{% endblock %}

{% block body %}
    <p><a href="{{ path('admin_home') }}" class="text-decoration-none">← Administrace</a></p>
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0">Svalové partie</h1>
        <a class="btn btn-primary btn-sm" href="{{ path('admin_muscle_group_new') }}">+ Nová partie</a>
    </div>
    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>Název</th>
                    <th>Počet cviků</th>
                    <th class="text-end">Akce</th>
                </tr>
            </thead>
            <tbody>
                {% for mg in muscleGroups %}
                    <tr>
                        <td>{{ mg.name }}</td>
                        <td>{{ mg.exercises|length }}</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-primary" href="{{ path('admin_muscle_group_edit', {id: mg.id}) }}">Upravit</a>
                            <form method="post" action="{{ path('admin_muscle_group_delete', {id: mg.id}) }}" class="d-inline"
                                  onsubmit="return confirm('Opravdu smazat partii „{{ mg.name|e('js') }}"?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('admin_muscle_group_delete_' ~ mg.id) }}">
                                <button type="submit" class="btn btn-sm btn-outline-danger" {{ mg.exercises|length > 0 ? 'disabled' : '' }}>Smazat</button>
                            </form>
                        </td>
                    </tr>
                {% else %}
                    <tr><td colspan="3" class="text-secondary"><em>Žádné svalové partie. Spusťte fixtures: <code>php bin/console doctrine:fixtures:load --append</code>.</em></td></tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
