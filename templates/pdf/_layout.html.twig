<!DOCTYPE html>
<html lang="cs">
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}TrainLog export{% endblock %}</title>
        <style>
            * { box-sizing: border-box; }
            body { font-family: "DejaVu Sans", sans-serif; font-size: 11pt; color: #222; margin: 0; }
            h1 { font-size: 18pt; margin: 0 0 0.2em; }
            h2 { font-size: 13pt; margin: 1.2em 0 0.3em; }
            .muted { color: #666; font-size: 10pt; }
            table { border-collapse: collapse; width: 100%; margin: 0.4em 0 1em; }
            th, td { border: 1px solid #ddd; padding: 4px 8px; text-align: left; font-size: 10pt; }
            th { background: #f5f5f5; }
            .summary { background: #fafafa; padding: 8px 12px; border: 1px solid #eee; margin: 0.5em 0; }
            .footer { margin-top: 2em; color: #999; font-size: 9pt; border-top: 1px solid #ddd; padding-top: 6px; }
        </style>
    </head>
    <body>
        {% block content %}{% endblock %}
        <div class="footer">TrainLog · vygenerováno {{ "now"|date('Y-m-d H:i') }}</div>
    </body>
</html>
