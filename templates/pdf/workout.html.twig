{% extends 'pdf/_layout.html.twig' %}

{% block title %}TrainLog — {{ workout.name }}{% endblock %}

{% block content %}
    <h1>{{ workout.name }}</h1>
    <div class="muted">
        {{ workout.performedAt|date('Y-m-d') }}
        {% if workout.durationMinutes %} · {{ workout.durationMinutes }} min{% endif %}
        {% if workout.user %} · {{ workout.user.name }}{% endif %}
    </div>

    {% if workout.note %}
        <p>{{ workout.note }}</p>
    {% endif %}

    {% set totalVolume = 0 %}
    {% for s in workout.sets %}{% set totalVolume = totalVolume + s.volume %}{% endfor %}

    {% for entry in byExercise %}
        {% set ex = entry.exercise %}
        {% set sets = entry.sets %}
        {% set exVolume = 0 %}
        {% set maxWeight = 0 %}
        {% for s in sets %}
            {% set exVolume = exVolume + s.volume %}
            {% if s.weightKgAsFloat > maxWeight %}{% set maxWeight = s.weightKgAsFloat %}{% endif %}
        {% endfor %}
        <h2>{{ ex.name }}</h2>
        <div class="muted">{{ sets|length }} sad · max {{ maxWeight }} kg · objem {{ exVolume|number_format(0, ',', ' ') }} kg</div>
        <table>
            <thead>
                <tr>
                    <th>Sada</th>
                    <th>Opakování</th>
                    <th>Váha (kg)</th>
                    <th>RPE</th>
                    <th>Objem (kg)</th>
                </tr>
            </thead>
            <tbody>
                {% for s in sets %}
                    <tr>
                        <td>{{ s.position }}</td>
                        <td>{{ s.reps }}</td>
                        <td>{{ s.weightKg }}</td>
                        <td>{{ s.rpe ?? '—' }}</td>
                        <td>{{ s.volume|number_format(0, ',', ' ') }}</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% endfor %}

    <div class="summary">
        <strong>Celkový objem tréninku:</strong> {{ totalVolume|number_format(0, ',', ' ') }} kg
    </div>
{% endblock %}
