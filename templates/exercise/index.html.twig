{% extends 'base.html.twig' %}

{% block title %}TrainLog — cviky{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0">Cviky</h1>
        <a class="btn btn-primary btn-sm" href="{{ path('exercise_new') }}">+ Nový cvik</a>
    </div>

    <form method="get" class="card card-body mb-4">
        <div class="mb-2 fw-semibold">Filtrovat podle svalové partie</div>
        <div class="row g-2">
            {% for mg in muscleGroups %}
                <div class="col-sm-4 col-md-3">
                    <div class="form-check">
                        <input type="checkbox" class="form-check-input" id="mg-{{ mg.id }}" name="muscle_group[]" value="{{ mg.id }}"
                               {% if mg.id in selectedIds %}checked{% endif %}>
                        <label class="form-check-label" for="mg-{{ mg.id }}">{{ mg.name }}</label>
                    </div>
                </div>
            {% endfor %}
        </div>
        <div class="mt-3">
            <button type="submit" class="btn btn-outline-primary btn-sm">Filtrovat</button>
            {% if selectedIds is not empty %}
                <a class="btn btn-outline-secondary btn-sm" href="{{ path('exercise_index') }}">Zrušit filtr</a>
            {% endif %}
        </div>
    </form>

    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>Název</th>
                    <th>Svalové partie</th>
                    <th>Vlastník</th>
                    <th>Veřejný</th>
                    <th class="text-end">Akce</th>
                </tr>
            </thead>
            <tbody>
                {% for exercise in items %}
                    <tr>
                        <td><a href="{{ path('exercise_show', {id: exercise.id}) }}">{{ exercise.name }}</a></td>
                        <td>
                            {% for mg in exercise.muscleGroups %}
                                <span class="badge text-bg-light border">{{ mg.name }}</span>
                            {% endfor %}
                        </td>
                        <td>{{ exercise.owner == app.user ? 'já' : exercise.owner.name }}</td>
                        <td>
                            {% if exercise.isPublic %}
                                <span class="badge text-bg-success">veřejný</span>
                            {% else %}
                                <span class="badge text-bg-secondary">soukromý</span>
                            {% endif %}
                        </td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-primary" href="{{ path('exercise_show', {id: exercise.id}) }}">Detail</a>
                            {% if is_granted('EXERCISE_EDIT', exercise) %}
                                <a class="btn btn-sm btn-outline-secondary" href="{{ path('exercise_edit', {id: exercise.id}) }}">Upravit</a>
                            {% endif %}
                        </td>
                    </tr>
                {% else %}
                    <tr><td colspan="5" class="text-secondary"><em>Žádné cviky neodpovídají filtru.</em></td></tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    {% set pages = (totalCount / perPage)|round(0, 'ceil') %}
    {% if pages > 1 %}
        <nav>
            <ul class="pagination">
                {% for i in 1..pages %}
                    <li class="page-item {% if i == page %}active{% endif %}">
                        <a class="page-link" href="{{ path('exercise_index', app.request.query.all|merge({page: i})) }}">{{ i }}</a>
                    </li>
                {% endfor %}
            </ul>
        </nav>
    {% endif %}
{% endblock %}
