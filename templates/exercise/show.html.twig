{% extends 'base.html.twig' %}

{% block title %}TrainLog — {{ exercise.name }}{% endblock %}

{% block body %}
    <p><a href="{{ path('exercise_index') }}" class="text-decoration-none">← Cviky</a></p>

    <div class="d-flex justify-content-between align-items-start mb-3">
        <div>
            <h1 class="h3 mb-1">{{ exercise.name }}</h1>
            <div>
                {% for mg in exercise.muscleGroups %}
                    <span class="badge text-bg-light border">{{ mg.name }}</span>
                {% endfor %}
                {% if exercise.isPublic %}
                    <span class="badge text-bg-success">veřejný</span>
                {% else %}
                    <span class="badge text-bg-secondary">soukromý</span>
                {% endif %}
            </div>
            <div class="text-secondary small mt-1">Vlastník: {{ exercise.owner == app.user ? 'já' : exercise.owner.name }}</div>
        </div>
        <div class="text-end">
            {% if is_granted('EXERCISE_EDIT', exercise) %}
                <a class="btn btn-sm btn-outline-secondary" href="{{ path('exercise_edit', {id: exercise.id}) }}">Upravit</a>
            {% endif %}
            <a class="btn btn-sm btn-outline-primary" href="{{ path('exercise_progress', {id: exercise.id}) }}">Vývoj</a>
            {% if is_granted('EXERCISE_DELETE', exercise) %}
                <form method="post" action="{{ path('exercise_delete', {id: exercise.id}) }}" class="d-inline"
                      onsubmit="return confirm('Opravdu smazat cvik „{{ exercise.name|e('js') }}"?');">
                    <input type="hidden" name="_token" value="{{ csrf_token('exercise_delete_' ~ exercise.id) }}">
                    <button type="submit" class="btn btn-sm btn-outline-danger">Smazat</button>
                </form>
            {% endif %}
        </div>
    </div>

    {% if exercise.description %}
        <div class="card card-body mb-4">{{ exercise.description|nl2br }}</div>
    {% endif %}

    <h2 class="h5">Poslední série</h2>
    {% if recentSets is empty %}
        <p class="text-secondary"><em>Zatím žádné série s tímto cvikem.</em></p>
    {% else %}
        <div class="table-responsive">
            <table class="table table-sm table-striped align-middle">
                <thead>
                    <tr>
                        <th>Datum</th>
                        <th>Trénink</th>
                        <th>Sada</th>
                        <th>Opak.</th>
                        <th>Váha (kg)</th>
                        <th>RPE</th>
                        <th>PR</th>
                    </tr>
                </thead>
                <tbody>
                    {% for set in recentSets %}
                        <tr>
                            <td>{{ set.workout.performedAt|date('Y-m-d') }}</td>
                            <td><a href="{{ path('workout_show', {id: set.workout.id}) }}">{{ set.workout.name }}</a></td>
                            <td>{{ set.position }}</td>
                            <td>{{ set.reps }}</td>
                            <td>{{ set.weightKg }}</td>
                            <td>{{ set.rpe ?? '—' }}</td>
                            <td>
                                {% for kind in prMap[set.id] ?? [] %}
                                    <span class="badge text-bg-warning">🏆 PR — {{ kind }}</span>
                                {% endfor %}
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}
{% endblock %}
