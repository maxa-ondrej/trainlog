# Copy to .env.local and fill in real values for your machine.
# .env.local is gitignored — never commit secrets.

###> symfony/framework-bundle ###
APP_ENV=dev
# Generate with: openssl rand -hex 32
APP_SECRET=
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> symfony/routing ###
# Configure how to generate URLs in non-HTTP contexts, such as CLI commands.
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> doctrine/doctrine-bundle ###
# Adjust if your MariaDB password contains shell-unsafe chars; URL-encode them.
# Format: mysql://USER:PASSWORD@HOST:PORT/DB?serverVersion=VERSION&charset=utf8mb4
DATABASE_URL="mysql://app:!ChangeMe!@127.0.0.1:3306/trainlog?serverVersion=10.11.6-MariaDB&charset=utf8mb4"
###< doctrine/doctrine-bundle ###
